{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vox Flow",
  "version": "0.1.3",
  "identifier": "com.2bworld.vox-flow",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vox Flow",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMjlGNEUwQUM0N0FFMApSV1RnZXNRS1RwOENEL29Rb2N1M1RIcVRCdWpNYUlIcmJtS24vcTEwYU1RRnpTb0czcmV6STNRMQo=",
      "endpoints": [
        "https://github.com/mythchow/VoxFlow/releases/latest/download/latest.json"
      ]
    }
  }
}
